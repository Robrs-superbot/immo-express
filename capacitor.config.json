{
  "appId": "com.immoexpress.app",
  "appName": "ImmoExpress",
  "webDir": "www",
  "bundledWebRuntime": false,
  "server": {
    "androidScheme": "https",
    "cleartext": true
  },
  "android": {
    "allowMixedContent": true
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 2000,
      "backgroundColor": "#0b0b0d",
      "androidSplashResourceName": "splash"
    }
  }
}
